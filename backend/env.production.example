PORT=4000
NODE_ENV=production
DATABASE_URL=postgresql://postgres:postgres@db-host:5432/upps
CORS_ORIGIN=https://your-domain.com
FREE_DAILY_QUESTION_LIMIT=30

AIRTEL_BASE_URL=https://openapiuat.airtel.co.zm
AIRTEL_PROD_BASE_URL=https://openapi.airtel.co.zm
AIRTEL_CLIENT_ID=replace-with-airtel-client-id
AIRTEL_CLIENT_SECRET=replace-with-airtel-client-secret
AIRTEL_COUNTRY_CODE=ZM
AIRTEL_CURRENCY=ZMW
AIRTEL_AUTH_PATH=/auth/oauth2/token
AIRTEL_COLLECTION_PATH=/merchant/v1/payments/
AIRTEL_CALLBACK_URL=
AIRTEL_TIMEOUT_MS=15000

FLW_BASE_URL=https://api.flutterwave.com
FLW_SECRET_KEY=replace-with-flutterwave-secret-key
FLW_WEBHOOK_HASH=replace-with-flutterwave-webhook-hash
FLW_REDIRECT_URL=https://your-domain.com/paywall
FLW_TIMEOUT_MS=15000

PAYMENT_WEBHOOK_SECRET=replace-with-strong-random-webhook-secret
ADMIN_API_KEY=replace-with-strong-admin-api-key
