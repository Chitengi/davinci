# Compose variable file for docker-compose.hostinger.yml
# Copy to .env on VPS (same folder as compose file) and fill values.

# Frontend build-time Vite vars
VITE_API_BASE_URL=/api/v1
VITE_ENABLE_SUBSCRIPTION_CHECKS=true
VITE_FLW_PUBLIC_KEY=FLWPUBK_TEST-REPLACE_ME
VITE_FLW_PAYMENT_OPTIONS=mobilemoney
